PORT=3001
HOST=0.0.0.0

# Supabase Postgres connection string. Get yours from
# Project Settings → Database → Connection string (URI mode).
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=no-verify"

# Random secret for signing JWTs. Use `openssl rand -hex 32` to generate.
JWT_SECRET="replace-with-a-long-random-string"
